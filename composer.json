{
    "name": "bvp/prefecture",
    "description": "BVP Prefecture",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "boatrace",
        "library",
        "prefecture"
    ],
    "authors": [
        {
            "name": "shimomo",
            "email": "bvp@shimomo.net"
        }
    ],
    "support": {
        "issues": "https://github.com/boatracevibeproject/prefecture/issues",
        "source": "https://github.com/boatracevibeproject/prefecture"
    },
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "ergebnis/composer-normalize": "^2.52",
        "phpunit/phpunit": "^13.0",
        "vimeo/psalm": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "BVP\\Prefecture\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BVP\\Prefecture\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "$schema": "https://getcomposer.org/schema.json"
}
